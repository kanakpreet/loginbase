<!-- views/salesrep-report.ejs -->
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Sales Rep Report - <%= salesRep.name %></title>
    <link rel="stylesheet" href="/style.css">
    <style>
        .top-nav {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 10px;
            padding: 10px 20px;
        }

        .top-nav a.nav-link {
            color: white;
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 5px;
            font-size: 14px;
            font-weight: 600;
            transition: background 0.2s;
            display: inline-block;
            margin: 0;
        }

        .top-nav .nav-home {
            background-color: #3498db;
        }

        .top-nav .nav-home:hover {
            background-color: #2980b9;
        }

        .top-nav .nav-logout {
            background-color: #e74c3c;
        }

        .top-nav .nav-logout:hover {
            background-color: #c0392b;
        }

        html,
        body {
            height: auto !important;
            display: block !important;
            justify-content: initial !important;
            align-items: initial !important;
            overflow: auto !important;
            font-family: Arial, sans-serif;
            background-color: #f0f0f0;
            margin: 0;
            padding: 0;
        }

        body {
            padding: 20px;
            min-height: 100vh;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            background-color: white;
            padding: 20px;
            border-radius: 5px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            position: relative;
        }

        h1 {
            margin: 0 0 5px 0;
            color: #333;
        }

        h2 {
            margin: 30px 0 15px 0;
            color: #333;
            border-bottom: 2px solid #007bff;
            padding-bottom: 10px;
        }

        .subtitle {
            color: #666;
            margin-bottom: 20px;
            font-size: 14px;
        }

        .action-buttons {
            margin: 20px 0;
        }

        .action-buttons a {
            display: inline-block;
            padding: 10px 15px;
            margin-right: 10px;
            background-color: #007bff;
            color: white;
            text-decoration: none;
            border-radius: 5px;
        }

        .action-buttons a:hover {
            background-color: #0056b3;
        }

        .summary-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin: 20px 0;
        }

        .summary-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            border-radius: 10px;
            text-align: center;
        }

        .summary-card.green {
            background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        }

        .summary-card h3 {
            margin: 0 0 10px 0;
            font-size: 14px;
            opacity: 0.9;
        }

        .summary-card .amount {
            font-size: 24px;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .summary-card .commission {
            font-size: 16px;
            opacity: 0.9;
        }

        .table-wrapper {
            overflow-x: auto;
            margin: 20px 0;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th,
        td {
            border: 1px solid #ddd;
            padding: 12px 8px;
            text-align: left;
        }

        th {
            background-color: #f8f9fa;
            font-weight: bold;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        tr:nth-child(even) {
            background-color: #f9f9f9;
        }

        tr:hover {
            background-color: #e9ecef;
        }

        .money {
            text-align: right;
            font-family: monospace;
            font-size: 14px;
        }

        .empty-msg {
            color: #888;
            font-style: italic;
            margin: 20px 0;
        }

        .totals-row {
            font-weight: bold;
            background-color: #e8f4fd !important;
        }

        .badge {
            display: inline-block;
            padding: 3px 8px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: bold;
            text-transform: uppercase;
        }

        .badge-invoice {
            background-color: #007bff;
            color: white;
        }

        .badge-customer {
            background-color: #28a745;
            color: white;
        }

        .invoice-link {
            color: #007bff;
            text-decoration: none;
        }

        .invoice-link:hover {
            text-decoration: underline;
        }

        .commission-info {
            background-color: #e8f4fd;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
        }

        .commission-info strong {
            color: #007bff;
        }

        * {
            position: static;
        }

        .container {
            position: relative;
        }
    </style>
</head>

<body>
    <div class="top-nav">
        <a href="/admin" class="nav-link nav-home">🏠 Home</a>
        <a href="/logout" class="nav-link nav-logout">🔓 Logout</a>
    </div>
    <div class="container">
        <h1>Sales Rep Commission Report</h1>
        <p class="subtitle">Report for: <strong><%= salesRep.name %></strong></p>

        <div class="commission-info">
            <strong>Commission Rate:</strong> <%= commissionRate %>%
        </div>

        <div class="action-buttons">
            <a href="/admin/salesrep">Back to Sales Representatives</a>
            <a href="/admin">Back to Admin Home</a>
        </div>

        <h2>📊 Summary</h2>
        <div class="summary-cards">
            <div class="summary-card">
                <h3>Last 30 Days</h3>
                <div class="amount">$<%= totals.total30 %></div>
                <div class="commission">Commission: $<%= commissions.commission30 %></div>
            </div>
            <div class="summary-card">
                <h3>Last 90 Days</h3>
                <div class="amount">$<%= totals.total90 %></div>
                <div class="commission">Commission: $<%= commissions.commission90 %></div>
            </div>
            <div class="summary-card">
                <h3>Last 180 Days</h3>
                <div class="amount">$<%= totals.total180 %></div>
                <div class="commission">Commission: $<%= commissions.commission180 %></div>
            </div>
            <div class="summary-card green">
                <h3>All Time</h3>
                <div class="amount">$<%= totals.totalAll %></div>
                <div class="commission">Commission: $<%= commissions.commissionAll %></div>
            </div>
        </div>

        <h2>📋 Eligible Invoices</h2>
        <% if (invoiceDetails && invoiceDetails.length > 0) { %>
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>Invoice #</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Source</th>
                            <th style="text-align:right">Amount</th>
                            <th style="text-align:right">Commission (<%= commissionRate %>%)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% invoiceDetails.forEach(inv => { %>
                            <tr>
                                <td>
                                    <a href="/admin/invoices/<%= inv.invoiceNumber %>" class="invoice-link">
                                        <%= inv.invoiceNumber %>
                                    </a>
                                </td>
                                <td><%= inv.customer %></td>
                                <td><%= inv.dateFormatted %></td>
                                <td>
                                    <% if (inv.source === 'invoice') { %>
                                        <span class="badge badge-invoice">Invoice</span>
                                    <% } else { %>
                                        <span class="badge badge-customer">Customer</span>
                                    <% } %>
                                </td>
                                <td class="money">$<%= inv.totalAmount.toFixed(2) %></td>
                                <td class="money">$<%= (inv.totalAmount * parseFloat(commissionRate) / 100).toFixed(2) %></td>
                            </tr>
                        <% }); %>
                        <tr class="totals-row">
                            <td colspan="4"><strong>Total</strong></td>
                            <td class="money">$<%= totals.totalAll %></td>
                            <td class="money">$<%= commissions.commissionAll %></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <p class="empty-msg">No invoices are assigned to this sales rep yet.</p>
        <% } %>
    </div>
</body>

</html>