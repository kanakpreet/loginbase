<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Checkout</title>
    <style>
        .top-nav {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 10px;
            padding: 10px 20px;
        }

        .top-nav a {
            color: white;
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 5px;
            font-size: 14px;
            font-weight: 600;
            transition: background 0.2s;
        }

        .top-nav .nav-home {
            background-color: #3498db;
        }

        .top-nav .nav-home:hover {
            background-color: #2980b9;
        }

        .top-nav .nav-logout {
            background-color: #e74c3c;
        }

        .top-nav .nav-logout:hover {
            background-color: #c0392b;
        }

        /* Add your styles here */
    </style>
</head>

<body>
    <div class="top-nav">
        <a href="/products" class="nav-home">🏠 Home</a>
        <a href="/logout" class="nav-logout">🔓 Logout</a>
    </div>
    <h1>Checkout Summary</h1>
    <table>
        <tr>
            <th>Item Name</th>
            <th>Quantity</th>
            <th>Price (per unit)</th>
            <th>Total</th>
        </tr>
        <% cart.forEach(item=> { %>
            <tr>
                <td>
                    <%= item.itemName %>
                </td>
                <td>
                    <%= item.quantity %>
                </td>
                <td>$<%= item.price.toFixed(2) %>
                </td>
                <td>$<%= (item.quantity * item.price).toFixed(2) %>
                </td>
            </tr>
            <% }); %>
    </table>

    <p>Subtotal: $<%= subtotal %>
    </p>
    <p>Sales Tax: $<%= salesTax %>
    </p>
    <h4>Total Amount: $<%= totalAmount %>
    </h4>

    <form action="/checkout" method="post">
        <button type="submit">Submit Order</button>
    </form>

    <form action="/cart" method="get">
        <button type="button" onclick="window.history.back();">Back to Cart</button>
    </form>
</body>

</html>