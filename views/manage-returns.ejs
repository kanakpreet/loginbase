<!DOCTYPE html>
<html>

<head>
    <title>Manage Returns</title>
    <style>
        .top-nav {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 10px;
            padding: 10px 20px;
        }

        .top-nav a {
            color: white;
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 5px;
            font-size: 14px;
            font-weight: 600;
            transition: background 0.2s;
        }

        .top-nav .nav-home {
            background-color: #3498db;
        }

        .top-nav .nav-home:hover {
            background-color: #2980b9;
        }

        .top-nav .nav-logout {
            background-color: #e74c3c;
        }

        .top-nav .nav-logout:hover {
            background-color: #c0392b;
        }
    </style>
</head>

<body>
    <div class="top-nav">
        <a href="/admin" class="nav-home">🏠 Home</a>
        <a href="/logout" class="nav-logout">🔓 Logout</a>
    </div>
    <h1>Returns</h1>
    <table>
        <thead>
            <tr>
                <th>Return Number</th>
                <th>Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% returns.forEach(r=> { %>
                <tr>
                    <td><a href="/admin/manageReturns/<%= r.returnNumber %>">
                            <%= r.returnNumber %>
                        </a></td>
                    <td>
                        <%= r.date %>
                    </td>
                    <td>
                        <%= r.processed ? "Processed" : "Not Processed" %>
                    </td>
                    <td><a href="/admin/manageReturns/<%= r.returnNumber %>">View</a></td>
                </tr>
                <% }) %>
        </tbody>
    </table>
</body>

</html>