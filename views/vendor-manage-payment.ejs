<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vendor Manage Payments</title>
    <!-- Add your CSS stylesheets or other head content here -->
    <style>
        .top-nav {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 10px;
            padding: 10px 20px;
        }

        .top-nav a {
            color: white;
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 5px;
            font-size: 14px;
            font-weight: 600;
            transition: background 0.2s;
        }

        .top-nav .nav-home {
            background-color: #3498db;
        }

        .top-nav .nav-home:hover {
            background-color: #2980b9;
        }

        .top-nav .nav-logout {
            background-color: #e74c3c;
        }

        .top-nav .nav-logout:hover {
            background-color: #c0392b;
        }

        /* Add your custom CSS styles here */
        body {
            font-family: Arial, sans-serif;
        }

        h1 {
            color: blue;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        th,
        td {
            border: 1px solid #dddddd;
            padding: 8px;
            text-align: left;
        }

        th {
            background-color: #f2f2f2;
        }

        .actions {
            margin-top: 20px;
        }

        .actions button {
            margin-right: 10px;
        }

        .btn-danger {
            background-color: #ff6666;
            color: white;
            border: none;
            padding: 8px 12px;
            cursor: pointer;
        }

        .btn-primary {
            background-color: #66b3ff;
            color: white;
            border: none;
            padding: 8px 12px;
            cursor: pointer;
            text-decoration: none;
        }
    </style>
</head>

<body>
    <div class="top-nav">
        <a href="/admin" class="nav-home">🏠 Home</a>
        <a href="/logout" class="nav-logout">🔓 Logout</a>
    </div>
    <div class="container">
        <h1>Vendor Manage Payments</h1>
        <table>
            <thead>
                <tr>
                    <th>Purchase ID</th>
                    <th>Vendor Name</th>
                    <th>Date Created</th>
                    <th>Invoice Total</th>
                    <th>Account Balance</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <% purchases.forEach(purchase=> { %>
                    <tr>
                        <td>
                            <%= purchase.PurchaseID %>
                        </td>
                        <td>
                            <%= purchase.vendorName %>
                        </td>
                        <td>
                            <%= purchase.dateCreated %>
                        </td>
                        <td>$<%= ((purchase.invoiceTotal || 0)).toFixed(2) %>
                        </td>
                        <td>$<%= ((purchase.accountBalance || 0)).toFixed(2) %>
                        </td>
                        <td>
                            <%= purchase.paid ? 'Paid' : 'Unpaid' %>
                        </td>
                        <td>
                            <!-- Go to Purchase Button -->
                            <a href="/admin/purchases/<%= purchase.PurchaseID %>" class="btn btn-primary">Go to
                                Purchase</a>

                            <!-- Delete Button -->
                            <button onclick="confirmDelete('<%= purchase.PurchaseID %>')"
                                class="btn btn-danger">Delete</button>
                        </td>
                    </tr>
                    <% }); %>
            </tbody>
        </table>
        <div class="actions">
            <form action="/admin" method="get">
                <button type="submit">Go Back to Admin Dashboard</button>
            </form>
            <form action="/logout" method="get">
                <button type="submit">Logout</button>
            </form>
        </div>
    </div>
    <script>
        function confirmDelete(purchaseID) {
            if (confirm('Are you sure you want to delete this purchase?')) {
                fetch(`/admin/purchases/delete/${purchaseID}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                })
                    .then(response => {
                        if (response.ok) {
                            location.reload();
                        } else {
                            alert('Error deleting purchase.');
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('Error deleting purchase.');
                    });
            }
        }
    </script>
    <!-- Add your scripts or other body content here -->
</body>

</html>