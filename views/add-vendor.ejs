<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Vendor - Admin</title>
    <style>
        .top-nav {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 10px;
            padding: 10px 20px;
            
        }

        .top-nav a.nav-link {
            color: white;
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 5px;
            font-size: 14px;
            font-weight: 600;
            transition: background 0.2s;
            display: inline-block;
            margin: 0;
        }

        .top-nav .nav-home {
            background-color: #3498db;
        }

        .top-nav .nav-home:hover {
            background-color: #2980b9;
        }

        .top-nav .nav-logout {
            background-color: #e74c3c;
        }

        .top-nav .nav-logout:hover {
            background-color: #c0392b;
        }

        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            margin: 0;
            padding: 20px;
        }

        .container {
            max-width: 600px;
            margin: 0 auto;
            background-color: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }

        h1 {
            color: #333;
        }

        form {
            display: flex;
            flex-direction: column;
        }

        label {
            margin-bottom: 5px;
            font-weight: bold;
        }

        input[type="text"],
        input[type="email"] {
            padding: 10px;
            margin-bottom: 15px;
            border: 1px solid #ccc;
            border-radius: 4px;
            font-size: 16px;
        }

        button {
            padding: 10px 15px;
            background-color: #28a745;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 16px;
        }

        button:hover {
            background-color: #218838;
        }

        .back-link {
            display: inline-block;
            margin-bottom: 20px;
            padding: 10px 15px;
            background-color: #6c757d;
            color: white;
            text-decoration: none;
            border-radius: 5px;
        }

        .back-link:hover {
            background-color: #545b62;
        }
    </style>
</head>

<body>
    <div class="top-nav">
        <a href="/admin" class="nav-link nav-home">🏠 Home</a>
        <a href="/logout" class="nav-link nav-logout">🔓 Logout</a>
    </div>
    <div class="container">
        <a href="/admin/view-vendors" class="back-link">Back to Vendors</a>
        <h1>Add New Vendor</h1>
        <form action="/admin/add-vendor" method="post">
            <label for="email">Email:</label>
            <input type="email" id="email" name="email" placeholder="Email" required>

            <label for="company">Company Name:</label>
            <input type="text" id="company" name="company" placeholder="Company Name" required>

            <label for="phone">Phone Number:</label>
            <input type="text" id="phone" name="phone" placeholder="Phone Number" required>

            <label for="addressLine1">Address Line 1:</label>
            <input type="text" id="addressLine1" name="addressLine1" placeholder="Address Line 1" required>

            <label for="addressLine2">Address Line 2:</label>
            <input type="text" id="addressLine2" name="addressLine2" placeholder="Address Line 2">

            <label for="city">City:</label>
            <input type="text" id="city" name="city" placeholder="City" required>

            <label for="state">State:</label>
            <input type="text" id="state" name="state" placeholder="State" required>

            <label for="zipCode">Zip Code:</label>
            <input type="text" id="zipCode" name="zipCode" placeholder="Zip Code" required>

            <button type="submit">Add Vendor</button>
        </form>
    </div>
</body>

</html>